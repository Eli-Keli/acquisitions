# Copy to .env.development and fill in your Neon credentials.
# Do not commit .env.development with real secrets.

# Development Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Neon Local (Docker Compose service name: neon-local)
NEON_LOCAL=true
NEON_FETCH_ENDPOINT=http://neon-local:5432/sql
DATABASE_URL=postgres://neon:npg@neon-local:5432/neondb?sslmode=require

# Neon Local proxy credentials (required by the neon-local container)
NEON_API_KEY=your_neon_api_key
NEON_PROJECT_ID=your_neon_project_id
PARENT_BRANCH_ID=br-xxx

# Auth
JWT_SECRET=dev-jwt-secret-change-me

# Arcjet
ARCJET_ENV=development
ARCJET_KEY=ajkey_yourkey
