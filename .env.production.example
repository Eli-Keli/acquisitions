# Copy to .env.production and fill in real values, or inject via your deploy platform.
# Do not commit .env.production with real secrets.

PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Neon Cloud (no Neon Local in production)
NEON_LOCAL=false
DATABASE_URL=postgres://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

JWT_SECRET=replace-with-a-strong-random-secret

ARCJET_ENV=production
ARCJET_KEY=ajkey_your_production_key

# Set to true on first deploy or when migrations are pending (run migrations via CI instead)
# RUN_MIGRATIONS=false
