# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database Configuration
# Local Docker (Neon Local): see .env.development
# Production (Neon Cloud): see .env.production.example
DATABASE_URL=

# Neon Local (development Docker only)
NEON_LOCAL=false
NEON_FETCH_ENDPOINT=http://neon-local:5432/sql

# Neon Local proxy (required when running docker-compose.dev.yml)
NEON_API_KEY=
NEON_PROJECT_ID=
PARENT_BRANCH_ID=

# Auth
JWT_SECRET=

# Arcjet
ARCJET_ENV=development
ARCJET_KEY=ajkey_yourkey